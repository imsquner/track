{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32F103 (OpenOCD + ST-Link)",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "servertype": "openocd",
      "device": "STM32F103C8",
